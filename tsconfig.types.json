{
  "include": ["src/*.*"],
  "exclude": ["**/*.js", "dist/**", "types/**", "node_modules/**"],
  "compilerOptions": {
    "moduleResolution": "node",
    "baseUrl": ".",
    "esModuleInterop": true,
    "declaration": true,
    "strict": false,
    "module": "ESNext",
    "downlevelIteration": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "target": "es2016",
    //"skipLibCheck": true,
    //"skipDefaultLibCheck": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "declarationDir": "types"
  }
}
